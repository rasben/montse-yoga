---
// Global site header — rendered on every page via Layout.astro so the logo,
// the three "Maria universes", and the language switcher are always one click away.
//
//   • For teachers     → /teacher-yoga  (yoga & breathwork)
//   • For brands       → /brands        (UGC / content creation)
//   • For readers      → the Substack blog
//
// Language switcher: a small dropdown that swaps the visitor between EN/ES/DA
// versions of the page they're currently on. Built with a <details>/<summary>
// so it works without JS and closes when you click outside (handled below).
import logo from '../assets/logo-wide.png';
import {
    asLang,
    useTranslations,
    localizedPath,
    stripLocale,
    LOCALES,
    localeLabel,
    localeFlag,
    htmlLang,
    type Lang,
} from '../i18n/utils';

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);

const path = Astro.url.pathname;
// normalise trailing slash for matching
const here = path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const links: Array<{ labelKey: string; href: string; external?: boolean }> = [
    { labelKey: 'common.nav.forTeachers', href: '/teacher-yoga' },
    { labelKey: 'common.nav.forBrands', href: '/brands' },
    { labelKey: 'common.nav.forReaders', href: 'https://mariamontserratmaria.substack.com/', external: true },
];

// For the language switcher we need the equivalent of the current page in each
// other language — strip the current locale prefix, then re-add the target one.
const { rest: pathWithoutLocale } = stripLocale(path);
const langOptions: Array<{ lang: Lang; href: string; label: string; flag: string }> = LOCALES.map((l) => ({
    lang: l,
    href: localizedPath(pathWithoutLocale, l),
    label: localeLabel(l),
    flag: localeFlag(l),
}));
const homeHref = localizedPath('/', lang);
---

<header id="site-header" class="sticky top-0 z-50 border-b border-primary-900/10 bg-primary-100">
    <div class="mx-auto flex flex-col items-center gap-2 px-6 py-3 sm:flex-row sm:justify-between md:px-10">
        <a href={homeHref} class="flex items-center" aria-label="Maria Montserrat — home">
            <img id="site-logo" src={logo.src} alt="Maria Montserrat" class="w-auto" />
        </a>

        <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-3">
            <nav aria-label="Primary" class="flex flex-wrap items-center justify-center gap-1 sm:gap-2">
                {links.map((l) => {
                    const localizedHref = l.external ? l.href : localizedPath(l.href, lang);
                    const active = !l.external && here === localizedHref;
                    return (
                        <a
                            href={localizedHref}
                            aria-current={active ? 'page' : undefined}
                            {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                            class={`rounded-full px-3 py-2 text-sm font-semibold transition sm:px-4 ${
                                active
                                    ? 'bg-primary-700 text-white'
                                    : 'text-stone-700 hover:bg-white/70 hover:text-primary-800'
                            }`}
                        >
                            {t(l.labelKey)}
                        </a>
                    );
                })}
            </nav>

            <!-- Language switcher -->
            <details class="lang-switcher relative">
                <summary
                    class="flex cursor-pointer list-none items-center gap-1.5 rounded-full bg-white/60 px-3 py-2 text-sm font-semibold text-stone-700 ring-1 ring-stone-900/5 transition hover:bg-white hover:text-primary-800"
                    aria-label={t('common.langSwitcher.label')}
                >
                    <span aria-hidden="true">{localeFlag(lang)}</span>
                    <span class="uppercase tracking-wider">{lang}</span>
                    <svg class="h-3.5 w-3.5 text-stone-500 transition-transform" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd"/></svg>
                </summary>
                <ul class="absolute right-0 z-50 mt-2 w-44 overflow-hidden rounded-2xl bg-white ring-1 ring-stone-900/10 shadow-lg shadow-primary-900/10">
                    {langOptions.map((opt) => (
                        <li>
                            <a
                                href={opt.href}
                                hreflang={htmlLang(opt.lang)}
                                aria-current={opt.lang === lang ? 'true' : undefined}
                                class={`flex items-center gap-3 px-4 py-2.5 text-sm transition ${
                                    opt.lang === lang
                                        ? 'bg-primary-50 font-semibold text-primary-800'
                                        : 'text-stone-700 hover:bg-primary-50 hover:text-primary-800'
                                }`}
                            >
                                <span aria-hidden="true" class="text-base leading-none">{opt.flag}</span>
                                <span>{opt.label}</span>
                            </a>
                        </li>
                    ))}
                </ul>
            </details>
        </div>
    </div>
</header>

<style>
    /* Logo is large at the top of the page, and shrinks once you scroll.
       Heights are driven here (not Tailwind) so the .scrolled toggle wins. */
    #site-logo {
        height: 6rem; /* 96px — top of page, mobile */
        transition: height 0.25s ease;
    }
    #site-header.scrolled #site-logo {
        height: 3rem; /* 48px — once scrolled, mobile */
    }
    @media (min-width: 640px) {
        #site-logo { height: 7rem; } /* 112px — top of page, desktop */
        #site-header.scrolled #site-logo { height: 3.5rem; } /* 56px — scrolled */
    }
    @media (prefers-reduced-motion: reduce) {
        #site-logo { transition: none; }
    }
    /* Hide the default ▶ marker on the language switcher summary. */
    .lang-switcher > summary {
        list-style: none;
    }
    .lang-switcher > summary::-webkit-details-marker {
        display: none;
    }
    .lang-switcher[open] > summary svg {
        transform: rotate(180deg);
    }
</style>

<script>
    // Shrink the logo unless we're at the very top of the page.
    const header = document.getElementById('site-header');
    if (header) {
        const update = () => header.classList.toggle('scrolled', window.scrollY > 8);
        update();
        window.addEventListener('scroll', update, { passive: true });
    }

    // Close the language switcher when the user clicks outside it.
    document.querySelectorAll<HTMLDetailsElement>('details.lang-switcher').forEach((det) => {
        document.addEventListener('click', (e) => {
            if (det.open && !det.contains(e.target as Node)) {
                det.open = false;
            }
        });
    });
</script>
