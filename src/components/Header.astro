---
// Global site header — rendered on every page via Layout.astro so the logo
// and the three "Maria universes" are always one click away.
//
//   • For teachers     → /teacher-yoga  (yoga & breathwork)
//   • For brands       → /brands        (UGC / content creation)
//   • For readers      → the Substack blog
import logo from '../assets/logo-wide.png';

const path = Astro.url.pathname;
// normalise trailing slash for matching
const here = path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const links = [
    { label: 'For teachers', href: '/teacher-yoga' },
    { label: 'For brands', href: '/brands' },
    { label: 'For readers', href: 'https://mariamontserratmaria.substack.com/', external: true },
];
---

<header id="site-header" class="sticky top-0 z-50 border-b border-primary-900/10 bg-primary-100">
    <div class="mx-auto flex flex-col items-center gap-2 px-6 py-3 sm:flex-row sm:justify-between md:px-10">
        <a href="/" class="flex items-center" aria-label="Maria Montserrat — home">
            <img id="site-logo" src={logo.src} alt="Maria Montserrat" class="w-auto" />
        </a>

        <nav aria-label="Primary" class="flex flex-wrap items-center justify-center gap-1 sm:gap-2">
            {links.map((l) => {
                const active = !l.external && here === l.href;
                return (
                    <a
                        href={l.href}
                        aria-current={active ? 'page' : undefined}
                        {...(l.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                        class={`rounded-full px-3 py-2 text-sm font-semibold transition sm:px-4 ${
                            active
                                ? 'bg-primary-700 text-white'
                                : 'text-stone-700 hover:bg-white/70 hover:text-primary-800'
                        }`}
                    >
                        {l.label}
                    </a>
                );
            })}
        </nav>
    </div>
</header>

<style>
    /* Logo is large at the top of the page, and shrinks once you scroll.
       Heights are driven here (not Tailwind) so the .scrolled toggle wins. */
    #site-logo {
        height: 6rem; /* 96px — top of page, mobile */
        transition: height 0.25s ease;
    }
    #site-header.scrolled #site-logo {
        height: 3rem; /* 48px — once scrolled, mobile */
    }
    @media (min-width: 640px) {
        #site-logo { height: 7rem; } /* 112px — top of page, desktop */
        #site-header.scrolled #site-logo { height: 3.5rem; } /* 56px — scrolled */
    }
    @media (prefers-reduced-motion: reduce) {
        #site-logo { transition: none; }
    }
</style>

<script>
    // Shrink the logo unless we're at the very top of the page.
    const header = document.getElementById('site-header');
    if (header) {
        const update = () => header.classList.toggle('scrolled', window.scrollY > 8);
        update();
        window.addEventListener('scroll', update, { passive: true });
    }
</script>
