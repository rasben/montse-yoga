---
// Courses CTA — compact front-page teaser that links to /courses.
// Shows thumbnail previews and a count so visitors get a feel for what's there,
// without making the home page any longer than it needs to be.

import courses from '../data/courses.json';

// Show up to 4 thumbnails as a visual teaser
const previews = courses.slice(0, 4);
const hasCourses = courses.length > 0;
---

<section id="courses-cta" class="relative overflow-hidden bg-sand-100 py-20 md:py-24">
    <div class="blob bg-primary-200" style="width: 360px; height: 360px; top: -80px; right: -80px; opacity: 0.4;"></div>
    <div class="blob bg-secondary-200" style="width: 280px; height: 280px; bottom: -60px; left: -60px; opacity: 0.35;"></div>

    <div class="relative mx-auto max-w-6xl px-6 md:px-10">
        <div class="flex flex-col items-center gap-12 md:flex-row md:gap-16">

            <!-- Thumbnail mosaic -->
            {hasCourses && (
                <div class="w-full shrink-0 md:w-80 lg:w-96">
                    <div class="grid grid-cols-2 gap-3">
                        {previews.map((course, i) => (
                            <div class={`overflow-hidden rounded-2xl shadow-md ${i === 0 ? 'col-span-2 h-44' : 'h-32'}`}>
                                {course.image ? (
                                    <img
                                        src={course.image}
                                        alt={course.title}
                                        class="h-full w-full object-cover"
                                        loading="lazy"
                                    />
                                ) : (
                                    <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-primary-100 to-secondary-100 text-3xl">🎓</div>
                                )}
                            </div>
                        ))}
                    </div>
                </div>
            )}

            <!-- Copy + CTA -->
            <div class="flex-1">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                    Online courses
                </p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    Take the practice <em class="font-normal text-primary-800">with you</em>.
                </h2>
                <p class="mt-5 max-w-lg text-lg leading-relaxed text-stone-700">
                    {hasCourses
                        ? `${courses.length} self-paced course${courses.length > 1 ? 's' : ''} for teachers, carers, and anyone ready to move beyond burnout — practice anywhere, at your own pace.`
                        : 'Self-paced courses for teachers, carers, and anyone ready to move beyond burnout — practice anywhere, at your own pace.'
                    }
                </p>
                <div class="mt-8 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
                    <a
                        href="/courses"
                        class="group inline-flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800"
                    >
                        Browse all courses
                        <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>
