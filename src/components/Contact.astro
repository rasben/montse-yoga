---
// Contact section — paired with the hero on the landing page.
// Uses a meditative namaste portrait of Maria as a soft visual anchor.
import maria from '../assets/maria-namaste.jpg';
import { Image } from 'astro:assets';

import {
    FacebookSolid,
    InstagramSolid,
    MailBoxOutline,
    PhoneOutline,
} from "flowbite-svelte-icons";
---

<section id="contact" class="relative overflow-hidden bg-sand-100 py-24 md:py-32">
    <!-- Soft background blobs continuing the hero's vibe -->
    <div class="blob bg-primary-200" style="width: 360px; height: 360px; top: -80px; left: -80px; opacity: 0.5;"></div>
    <div class="blob bg-secondary-200" style="width: 320px; height: 320px; bottom: -100px; right: -60px; opacity: 0.45;"></div>

    <div class="relative mx-auto grid max-w-6xl grid-cols-1 items-center gap-16 px-6 md:grid-cols-2 md:px-10">
        <!-- Photo -->
        <div class="relative order-2 md:order-1">
            <div
                class="absolute -inset-3 -z-10 bg-primary-200/60 blur-sm"
                style="border-radius: 48% 52% 60% 40% / 56% 44% 56% 44%;"
            ></div>
            <div
                class="relative overflow-hidden shadow-xl shadow-primary-900/15"
                style="border-radius: 48% 52% 60% 40% / 56% 44% 56% 44%;"
            >
                <Image
                    src={maria}
                    alt="Maria Montserrat in namaste, eyes closed in a moment of quiet"
                    widths={[420, 640, 800]}
                    sizes="(min-width: 768px) 40vw, 80vw"
                    class="h-[460px] w-full object-cover md:h-[540px]"
                />
            </div>
        </div>

        <!-- Copy + contact links -->
        <div class="order-1 md:order-2">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                Let's talk
            </p>

            <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl md:text-6xl">
                Whenever you're ready, <em class="font-normal text-primary-800">I'm here</em>.
            </h2>

            <p class="mt-6 max-w-lg text-lg leading-relaxed text-stone-800">
                Whether you're curious about a class in Copenhagen, an online course for
                educators, or you just want to ask a question — reach out. I read every
                message myself, and there is no pressure to commit to anything.
            </p>

            <ul class="mt-10 space-y-3">
                <li>
                    <a
                        href="mailto:maria@maria-montserrat.com"
                        class="group flex items-center gap-4 rounded-2xl bg-white/85 p-4 text-stone-900 ring-1 ring-stone-900/5 backdrop-blur-sm transition hover:bg-white hover:shadow-lg hover:shadow-primary-900/10"
                    >
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary-200 text-primary-800 transition group-hover:bg-primary-700 group-hover:text-white">
                            <MailBoxOutline class="h-5 w-5" />
                        </span>
                        <span class="flex flex-col">
                            <span class="text-xs font-semibold uppercase tracking-widest text-stone-700">Email</span>
                            <span class="font-medium">maria@maria-montserrat.com</span>
                        </span>
                    </a>
                </li>
                <li>
                    <a
                        href="tel:+4540305519"
                        class="group flex items-center gap-4 rounded-2xl bg-white/85 p-4 text-stone-900 ring-1 ring-stone-900/5 backdrop-blur-sm transition hover:bg-white hover:shadow-lg hover:shadow-primary-900/10"
                    >
                        <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-primary-200 text-primary-800 transition group-hover:bg-primary-700 group-hover:text-white">
                            <PhoneOutline class="h-5 w-5" />
                        </span>
                        <span class="flex flex-col">
                            <span class="text-xs font-semibold uppercase tracking-widest text-stone-700">Phone</span>
                            <span class="font-medium">+45 40 30 55 19</span>
                        </span>
                    </a>
                </li>
                <li class="grid grid-cols-2 gap-3">
                    <a
                        href="https://instagram.com/mariamontserratmaria/"
                        class="group flex items-center gap-3 rounded-2xl bg-white/85 p-4 text-stone-900 ring-1 ring-stone-900/5 backdrop-blur-sm transition hover:bg-white hover:shadow-lg hover:shadow-primary-900/10"
                    >
                        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-200 text-primary-800 transition group-hover:bg-primary-700 group-hover:text-white">
                            <InstagramSolid class="h-4 w-4" />
                        </span>
                        <span class="font-medium">Instagram</span>
                    </a>
                    <a
                        href="https://facebook.com/montserrat.alberola/"
                        class="group flex items-center gap-3 rounded-2xl bg-white/85 p-4 text-stone-900 ring-1 ring-stone-900/5 backdrop-blur-sm transition hover:bg-white hover:shadow-lg hover:shadow-primary-900/10"
                    >
                        <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary-200 text-primary-800 transition group-hover:bg-primary-700 group-hover:text-white">
                            <FacebookSolid class="h-4 w-4" />
                        </span>
                        <span class="font-medium">Facebook</span>
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <!-- Tiny footer flourish -->
    <div class="relative mx-auto mt-24 flex max-w-6xl items-center justify-center px-6 md:px-10">
        <p class="text-center font-display text-xl italic text-stone-700">
            namasté &mdash; the light in me honours the light in you
        </p>
    </div>
</section>
