---
// Dev-only theme switcher. Lets you flip between the default look and the
// alternate "bold" palette (see html.theme-bold in global.css) so you can
// show a louder design direction locally without shipping anything.
//
// Gated on import.meta.env.DEV — it renders ONLY under `npm run dev`, never
// in the production build. Safe to leave in place.
const isDev = import.meta.env.DEV;
---

{isDev && (
    <div id="theme-toggle" class="fixed bottom-4 right-4 z-50">
        <button
            type="button"
            id="theme-toggle-btn"
            class="flex items-center gap-2 rounded-full bg-stone-900/90 px-4 py-2.5 text-sm font-semibold text-white shadow-lg ring-1 ring-white/10 backdrop-blur transition hover:bg-stone-800"
        >
            <span class="inline-block h-3 w-3 rounded-full bg-gradient-to-br from-primary-500 to-secondary-500"></span>
            <span id="theme-toggle-label">Bold colours: off</span>
        </button>
    </div>

    <script is:inline>
        (function () {
            var KEY = 'montse-theme-bold';
            var root = document.documentElement;
            var btn = document.getElementById('theme-toggle-btn');
            var label = document.getElementById('theme-toggle-label');

            function apply(on) {
                root.classList.toggle('theme-bold', on);
                if (label) label.textContent = 'Bold colours: ' + (on ? 'on' : 'off');
            }

            apply(localStorage.getItem(KEY) === '1');

            if (btn) {
                btn.addEventListener('click', function () {
                    var on = !root.classList.contains('theme-bold');
                    localStorage.setItem(KEY, on ? '1' : '0');
                    apply(on);
                });
            }
        })();
    </script>
)}
