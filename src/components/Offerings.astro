---
// Offerings section — sits between the hero and the contact section.
// Leads with the burnout/audience positioning (teachers, carers, burned-out professionals),
// then shows the practices Maria uses to address that. The teaching styles are the
// HOW — the audience's situation is the headline.
import { asLang, useTranslations, useList, localizedPath } from '../i18n/utils';

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);
const list = useList(lang);

const audienceChips = list<string>('teacherYoga.offerings.audienceChips');
const cards = list<{ title: string; body: string }>('teacherYoga.offerings.cards');

// Decorative icons for each card — kept in code (not the dictionary) because
// they're visual chrome, not content. Order matches the cards array above.
const cardIcons = ['🌙', '🌬️', '🌿', '🌊', '🔥'];
const cardBg = ['bg-primary-100', 'bg-secondary-100', 'bg-primary-100', 'bg-primary-100', 'bg-secondary-100'];
---

<section id="offerings" class="relative overflow-hidden bg-secondary-100 py-24 md:py-32">

    <div class="relative mx-auto max-w-6xl px-6 md:px-10">

        <!-- Section header — burnout/audience first -->
        <div class="mx-auto max-w-2xl text-center">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                {t('teacherYoga.offerings.eyebrow')}
            </p>
            <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl" set:html={t('teacherYoga.offerings.title')}>
            </h2>
            <p class="mt-6 text-lg leading-relaxed text-stone-700" set:html={t('teacherYoga.offerings.intro')}>
            </p>
        </div>

        <!-- "Who this is for" chips -->
        <div class="mt-10 flex flex-wrap justify-center gap-3">
            {audienceChips.map((label) => (
                <span class="rounded-full bg-white px-4 py-2 text-sm font-medium text-stone-700 ring-1 ring-stone-900/8">
                    {label}
                </span>
            ))}
        </div>

        <!-- Offering cards -->
        <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">

            {cards.map((card, i) => (
                <article class="group relative rounded-3xl bg-sand-50 p-8 ring-1 ring-stone-900/5 transition hover:shadow-lg hover:shadow-primary-900/8">
                    <div class={`mb-5 flex h-14 w-14 items-center justify-center rounded-2xl text-2xl ${cardBg[i] ?? 'bg-primary-100'}`}>
                        {cardIcons[i] ?? '🌙'}
                    </div>
                    <h3 class="font-display text-2xl text-stone-900">{card.title}</h3>
                    <p class="mt-3 leading-relaxed text-stone-700">
                        {card.body}
                    </p>
                </article>
            ))}

            <!-- Online Courses — for educators specifically -->
            <article class="group relative rounded-3xl bg-primary-700 p-8 transition hover:bg-primary-800 hover:shadow-lg hover:shadow-primary-900/20">
                <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/20 text-2xl">
                    🎓
                </div>
                <h3 class="font-display text-2xl text-white">{t('teacherYoga.offerings.onlineCourses.title')}</h3>
                <p class="mt-3 leading-relaxed text-primary-100">
                    {t('teacherYoga.offerings.onlineCourses.body')}
                </p>
                <a
                    href={localizedPath('/courses', lang)}
                    class="mt-6 inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-primary-800 transition hover:bg-primary-50"
                >
                    {t('teacherYoga.offerings.onlineCourses.cta')}
                    <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>
            </article>

        </div>

        <!-- Maria's background, framed as credibility for this specific audience -->
        <p class="mx-auto mt-16 max-w-2xl text-center text-sm leading-relaxed text-stone-500">
            {t('teacherYoga.offerings.background')}
        </p>

    </div>
</section>
