---
// Soft-wellness hero for the /teacher-yoga page.
// Pairs a bold Playfair Display headline with a single warm photo of Maria
// over a solid colour block. Site nav lives in the global Header.
import maria from '../assets/maria-grass-seated.jpg';
import { Image } from 'astro:assets';
import { asLang, useTranslations, localizedPath } from '../i18n/utils';

const lang = asLang(Astro.currentLocale);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden">
    <!-- Solid warm cream background -->
    <div class="absolute inset-0 -z-20 bg-primary-100"></div>

    <!-- Hero content grid -->
    <div class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-6 pb-24 pt-14 md:grid-cols-12 md:gap-16 md:px-10 md:pb-32 md:pt-24">
        <!-- Copy column -->
        <div class="md:col-span-6 lg:col-span-6">
            <p class="fade-up text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                {t('teacherYoga.hero.eyebrow')}
            </p>

            <h1 class="fade-up-delay-1 mt-6 font-display text-5xl leading-[1.05] text-stone-900 sm:text-6xl md:text-7xl" set:html={t('teacherYoga.hero.headline')}>
            </h1>

            <p class="fade-up-delay-2 mt-8 max-w-xl text-lg leading-relaxed text-stone-800 md:text-xl">
                {t('teacherYoga.hero.body')}
            </p>

            <div class="fade-up-delay-3 mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
                <a
                    href="#contact"
                    class="group inline-flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800 hover:shadow-primary-800/40"
                >
                    {t('teacherYoga.hero.ctaPrimary')}
                    <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>

                <a
                    href={localizedPath('/courses', lang)}
                    class="inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-semibold text-stone-900 underline-offset-4 transition hover:text-primary-800 hover:underline"
                >
                    {t('teacherYoga.hero.ctaSecondary')}
                </a>
            </div>

            <!-- Tiny "where" indicator -->
            <div class="fade-up-delay-3 mt-12 flex items-center gap-3 text-sm font-medium text-stone-700">
                <svg class="h-4 w-4 text-primary-700" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
                <span>{t('teacherYoga.hero.where')}</span>
            </div>
        </div>

        <!-- Photo column -->
        <div class="fade-up-delay-2 relative md:col-span-6 lg:col-span-6">
            <div class="relative mx-auto max-w-md md:max-w-none">
                <!-- Backing organic shape -->
                <div
                    class="absolute -inset-4 -z-10 bg-secondary-500"
                    style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;"
                ></div>

                <!-- Photo masked into a soft organic shape -->
                <div
                    class="relative overflow-hidden shadow-2xl shadow-primary-900/20"
                    style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;"
                >
                    <Image
                        src={maria}
                        alt={t('teacherYoga.hero.photoAlt')}
                        widths={[480, 720, 960]}
                        sizes="(min-width: 768px) 50vw, 90vw"
                        class="h-[520px] w-full object-cover md:h-[640px]"
                        loading="eager"
                    />
                </div>

                <!-- Floating quote card -->
                <figure
                    class="absolute -bottom-6 -left-6 hidden max-w-[16rem] rounded-2xl bg-white p-5 shadow-xl shadow-primary-900/15 ring-1 ring-stone-900/5 sm:block md:-left-10"
                >
                    <svg class="h-6 w-6 text-primary-700" viewBox="0 0 24 24" fill="currentColor"><path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/></svg>
                    <blockquote class="mt-2 font-display text-lg italic leading-snug text-stone-900">
                        {t('teacherYoga.hero.quote')}
                    </blockquote>
                    <figcaption class="mt-2 text-xs font-semibold uppercase tracking-widest text-stone-700">
                        {t('teacherYoga.hero.quoteAttribution')}
                    </figcaption>
                </figure>
            </div>
        </div>
    </div>

    <!-- Scroll cue -->
    <div class="relative z-10 flex justify-center pb-10">
        <a href="#offerings" class="group flex flex-col items-center gap-2 text-xs font-semibold uppercase tracking-[0.3em] text-stone-700 transition hover:text-primary-800">
            <span>{t('teacherYoga.hero.scrollCue')}</span>
            <svg class="h-4 w-4 animate-bounce" viewBox="0 0 20 20" fill="currentColor"><path d="M10 14l-5-5h10l-5 5z"/></svg>
        </a>
    </div>
</section>
