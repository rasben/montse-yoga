---
// Soft-wellness hero for the maria-montserrat.com landing page.
// Pairs an editorial serif headline with a single warm photo of Maria,
// floating pastel "blobs" behind, and a minimal top navigation.
//
// Photo:
//   maria-grass-seated.jpg — Maria seated in lotus pose on grass,
//   soft natural light, warm welcoming expression. Picked for the
//   hero because it reads "grounded, peaceful, inviting" instantly.
import logo from '../assets/logo.png';
import maria from '../assets/maria-grass-seated.jpg';

import { Image } from 'astro:assets';
---

<section class="relative overflow-hidden">
    <!-- Soft pastel background gradient -->
    <div class="absolute inset-0 -z-20 bg-gradient-to-br from-sand-50 via-primary-50 to-secondary-50"></div>

    <!-- Floating decorative blobs (purely decorative, behind content) -->
    <div class="blob float-slow bg-primary-200" style="width: 480px; height: 480px; top: -120px; right: -80px;"></div>
    <div class="blob float-slower bg-secondary-200" style="width: 360px; height: 360px; bottom: -120px; left: -100px;"></div>
    <div class="blob float-slow bg-primary-300" style="width: 220px; height: 220px; top: 40%; left: 38%; opacity: 0.3;"></div>

    <!-- Minimal top navigation -->
    <nav class="relative z-10 mx-auto flex max-w-7xl items-center justify-between px-6 pt-6 md:px-10 md:pt-8 h-30">
        <a href="/" class="flex items-center gap-3" aria-label="Maria Montserrat — home">
            <img src={logo.src} alt="" class="h-30" />

            <h1 class="text-3xl">Maria Montserrat</h1>
        </a>

        <a
            href="#contact"
            class="inline-flex items-center text-center rounded-full border border-primary-700 bg-white/80 px-5 py-2 text-sm font-semibold text-primary-800 shadow-sm backdrop-blur-sm transition hover:bg-primary-700 hover:text-white"
        >
            Get in touch
        </a>
    </nav>

    <!-- Hero content grid -->
    <div class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-6 pb-24 pt-14 md:grid-cols-12 md:gap-16 md:px-10 md:pb-32 md:pt-24">
        <!-- Copy column -->
        <div class="md:col-span-6 lg:col-span-6">
            <p class="fade-up text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                For teachers &middot; Carers &middot; Anyone running on empty
            </p>

            <h1 class="fade-up-delay-1 mt-6 font-display text-5xl leading-[1.05] text-stone-900 sm:text-6xl md:text-7xl">
                Move beyond <br class="hidden sm:inline" />
                <em class="font-normal text-primary-800">burnout</em>.
            </h1>

            <p class="fade-up-delay-2 mt-8 max-w-xl text-lg leading-relaxed text-stone-800 md:text-xl">
                If you spend your days caring for others — teaching, nurturing, holding space
                — this is space held for you. Yoga and breathwork that calms your nervous
                system, not just your mind. Without pressure. Without perfection.
            </p>

            <div class="fade-up-delay-3 mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
                <a
                    href="#contact"
                    class="group inline-flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800 hover:shadow-primary-800/40"
                >
                    Practice with me
                    <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>

                <a
                    href="/courses"
                    class="inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-semibold text-stone-900 underline-offset-4 transition hover:text-primary-800 hover:underline"
                >
                    Explore online courses
                </a>
            </div>

            <!-- Tiny "where" indicator -->
            <div class="fade-up-delay-3 mt-12 flex items-center gap-3 text-sm font-medium text-stone-700">
                <svg class="h-4 w-4 text-primary-700" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
                <span>Copenhagen, Denmark &nbsp;·&nbsp; classes online worldwide</span>
            </div>
        </div>

        <!-- Photo column -->
        <div class="fade-up-delay-2 relative md:col-span-6 lg:col-span-6">
            <div class="relative mx-auto max-w-md md:max-w-none">
                <!-- Backing organic shape -->
                <div
                    class="absolute -inset-4 -z-10 bg-primary-200/70 blur-sm"
                    style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;"
                ></div>

                <!-- Photo masked into a soft organic shape -->
                <div
                    class="relative overflow-hidden shadow-2xl shadow-primary-900/20"
                    style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;"
                >
                    <Image
                        src={maria}
                        alt="Maria Montserrat seated in lotus pose on the grass"
                        widths={[480, 720, 960]}
                        sizes="(min-width: 768px) 50vw, 90vw"
                        class="h-[520px] w-full object-cover md:h-[640px]"
                        loading="eager"
                    />
                </div>

                <!-- Floating quote card -->
                <figure
                    class="absolute -bottom-6 -left-6 hidden max-w-[16rem] rounded-2xl bg-white/95 p-5 shadow-xl shadow-primary-900/15 ring-1 ring-stone-900/5 backdrop-blur-md sm:block md:-left-10"
                >
                    <svg class="h-6 w-6 text-primary-700" viewBox="0 0 24 24" fill="currentColor"><path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/></svg>
                    <blockquote class="mt-2 font-display text-lg italic leading-snug text-stone-900">
                        Yoga is the journey of the self, through the self, to the self.
                    </blockquote>
                    <figcaption class="mt-2 text-xs font-semibold uppercase tracking-widest text-stone-700">
                        Bhagavad Gita
                    </figcaption>
                </figure>
            </div>
        </div>
    </div>

    <!-- Scroll cue -->
    <div class="relative z-10 flex justify-center pb-10">
        <a href="#offerings" class="group flex flex-col items-center gap-2 text-xs font-semibold uppercase tracking-[0.3em] text-stone-700 transition hover:text-primary-800">
            <span>Explore</span>
            <svg class="h-4 w-4 animate-bounce" viewBox="0 0 20 20" fill="currentColor"><path d="M10 14l-5-5h10l-5 5z"/></svg>
        </a>
    </div>
</section>
