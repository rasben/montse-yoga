---
// "Brands" — Maria's UGC / content-creator page, ported from her Canva site
// (https://brands.maria-montserrat.com). Route: /brands
//
// This is Maria's *content-creator* persona (brand/UGC work), distinct from
// the teacher-yoga page. Rendered in the site's own design system
// (coral / sand / sky + Cormorant Garamond / Inter) rather than the magenta
// Canva theme, so the content lives in the "real" styling.
//
// IMAGES — TEMPORARY: the photos below are hot-linked straight from Maria's
// Canva site so we can preview the layout. They should be replaced with
// optimized local assets (drop files into src/assets/brands/ and switch
// to `astro:assets` <Image>) once Maria uploads the originals. Each image's
// Canva filename is the last path segment of its URL.
import Layout from '../layouts/Layout.astro';
import Langs from '../components/Langs.astro';

const CANVA = 'https://brands.maria-montserrat.com/_assets/media';
const img = (file: string) => `${CANVA}/${file}`;

// VIDEOS — hot-linked from Maria's Canva site, same as the images above.
// These are immutable, content-hashed static files (cache-control: immutable,
// range-supported), so the URLs are stable and safe to hot-link — but they're
// still served by Canva, so we pay their bandwidth on each view. Swap to local
// files in public/videos/ + a `/videos/...` src once Maria exports the
// originals, if we want to drop the Canva dependency entirely.
const CANVA_VIDEO = 'https://brands.maria-montserrat.com/_assets/video';
const vid = (hash: string) => `${CANVA_VIDEO}/${hash}.mp4`;

const BLOG_URL = 'https://mariamontserratmaria.substack.com/';

// Flag per language code, used on the spec-UGC cards.
const FLAG: Record<string, { flag: string; label: string }> = {
    EN: { flag: '🇬🇧', label: 'English' },
    ES: { flag: '🇪🇸 🇲🇽', label: 'Spanish' },
    DK: { flag: '🇩🇰', label: 'Danish' },
};

// Analytics — MANUAL SNAPSHOT (not live). These figures are typed in by hand
// from Maria's Instagram Insights / Meta Business Suite / TikTok Analytics, the
// same "update on demand" approach as the course listing. To refresh: open each
// platform's analytics, copy the headline numbers + growth %, and update below.
// `delta` is the percentage change the platform reports (positive = up). Each
// platform keeps its own `period` because their dashboards default differently.
// `newAudience` (0–100, optional) = share of reach from non-followers — the
// number brands care about most — and drives the little bar on the card.
// `period` is a FIXED date range (these are captured numbers, not a live rolling
// window) so the snapshot reads honestly.
const analyticsUpdated = 'May 2026';

const BRAND: Record<string, { color: string; svg: string }> = {
    Instagram: { color: '#E1306C', svg: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.3" fill="white" stroke="none"/></svg>' },
    TikTok: { color: '#111111', svg: '<svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M16 3c.3 2.2 1.8 3.9 4 4.2v2.6c-1.5 0-2.9-.5-4-1.3v5.9A5.7 5.7 0 1 1 10.3 8.7c.3 0 .6 0 .9.1v2.7a3 3 0 1 0 2.1 2.9V3H16z"/></svg>' },
    Facebook: { color: '#1877F2', svg: '<svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M14 9h2.5V6H14c-2 0-3.2 1.2-3.2 3.2V11H8.5v3h2.3v7h3v-7h2.3l.4-3h-2.7V9.5c0-.4.3-.5.6-.5z"/></svg>' },
};

const platforms = [
    {
        name: 'Instagram',
        handle: '@mariamontserratmaria',
        url: 'https://www.instagram.com/mariamontserratmaria/',
        period: '29 Apr – 26 May 2026',
        headline: { value: '1.1M', long: '1.1 million', label: 'Views', delta: 161.5 },
        metrics: [
            { value: '576.7K', label: 'Reach', delta: 149.3 },
            { value: '28K', label: 'Interactions', delta: 98.1 },
        ],
        newAudience: 98.3,
    },
    {
        name: 'TikTok',
        handle: '@mariamontserratmaria',
        url: 'https://www.tiktok.com/@mariamontserratmaria',
        period: '19 – 25 May 2026',
        headline: { value: '231.8K', long: '231,800', label: 'Video views', delta: 737.1 },
        metrics: [
            { value: '5.1K', label: 'Likes', delta: 744.4 },
            { value: '479', label: 'Shares', delta: 197.5 },
        ],
        newAudience: null,
        // TikTok dashboard doesn't report a follower/non-follower split, so the
        // card shows this honest virality note instead of the reach gauge.
        highlight: { stat: '424', text: 'followers — yet a single week reached 231.8K views' },
    },
    {
        name: 'Facebook',
        handle: 'mariamontserratmaria',
        url: 'https://www.facebook.com/mariamontserratmaria',
        period: '29 Apr – 26 May 2026',
        headline: { value: '28.2K', long: '28,200', label: 'Views', delta: 103.6 },
        metrics: [
            { value: '16,696', label: 'Viewers', delta: 127 },
            { value: '144', label: 'Interactions', delta: 108.7 },
        ],
        newAudience: 98.4,
    },
];

// Turn a display value like "1.1M", "576.7K" or "16,696" into the attributes the
// count-up script needs: the numeric target, any K/M suffix, decimal places, and
// whether to render thousands separators. Lets us animate without duplicating data.
function countAttrs(value: string) {
    const m = value.replace(/,/g, '').match(/^([\d.]+)\s*([KM%]?)/);
    const numStr = m?.[1] ?? '0';
    return {
        'data-count-to': numStr,
        'data-count-suffix': m?.[2] ?? '',
        'data-count-decimals': String((numStr.split('.')[1] ?? '').length),
        'data-count-sep': value.includes(',') ? '1' : '0',
    };
}

// "How I show up" — organic reels (personal brand). These are the three real
// organic videos on the Canva site; `video` is each clip's content hash, mapped
// confidently from each video's own caption (aria-label) on the source page.
const reels = [
    { title: 'Finding myself after burnout', tags: 'Emotional narrative · organic', video: '09d9617a6e0b7f73635171dcf4493806' },
    { title: 'Snapping at everyone you love', tags: 'Nervous system reel · organic', video: 'ea57e8a8be5dd671e5cd2e90abd0b601' },
    { title: 'Teacher Stress Reset', tags: 'Somatic tutorial · organic', video: '19ca814b78e3b5f398c8f0e2c82cad68' },
];

// "Spec UGC · ad-ready" — concept work shot in three languages. `video` is each
// clip's content hash. NOTE: the Canva markup made it impossible to pair each
// spec clip to its label with certainty, so these are attached in the source
// DOM order — eyeball the six clips and reorder the hashes if any label is off.
const specWork = [
    { hook: '10 years, same mat. Still my favourite.', type: 'Lifestyle testimonial', lang: 'EN', video: '90f1f16670ed5e36bf9ecb487ae572ed' },
    { hook: 'Lo primero antes de mirar el móvil.', type: 'Morning ritual', lang: 'ES', video: 'f9422c4ffcdb553b0cf4dc9473eaf053' },
    { hook: 'Min daglige kefir — sådan starter jeg dagen.', type: 'Food & health', lang: 'DK', video: '6787f00efb5f22019a059acbf6585404' },
    { hook: 'The serum that finally calmed my reactive skin.', type: 'Skincare testimonial', lang: 'EN', video: '8f50e2a7cec1afcffa95f33946373d60' },
    { hook: 'Mi rutina de noche en 30 segundos.', type: 'Skincare demo', lang: 'ES', video: 'f56f080685e4c0149194f247e30809b8' },
    { hook: 'Min morgenflow derhjemme.', type: 'Lifestyle · yoga', lang: 'DK', video: '1b171679299c6d0a1406b10aa4b9ec10' },
];

// Niches she creates for (text list — replaces the third-party brand-logo wall).
const niches = [
    'Skincare & beauty', 'Wellness & mindfulness', 'Lifestyle', 'Fashion',
    'Food & beverage', 'Travel & hospitality', 'Health & autoimmune',
    'Plant-based', 'Nervous-system recovery',
];

// Photography — hot-linked from Canva for now (see note above).
const photography = [
    { file: '867011bb5ed745b0d4a36ae51dc3b2df.jpg', alt: 'Lifestyle photograph — dog playing in the grass' },
    { file: '24772a4d9af8e44a2a8b452e99a4f8d9.jpg', alt: 'Food photograph — pistachio cannoli on a ceramic plate' },
    { file: 'ca6fcc9917b99d965ea3d04f0f0852b3.jpg', alt: 'Product photograph — skincare bottle and jar' },
    { file: '2e0df4d4e189a39fa8e45d288b14064f.jpg', alt: 'Lifestyle product photograph' },
    { file: 'a3d96731c504bc656f26e2b1816155f2.jpg', alt: 'Lifestyle photograph' },
    { file: '9d384f234a5cfac4ab2becceca767ef4.jpg', alt: 'Product & lifestyle photograph' },
];

const travel = [
    { file: '9fb3fa3cf2a6e98c2ec89ea9268a91cd.jpg', alt: 'Travel photograph — ancient temple' },
    { file: '68ea5af2ab5f6809d91cc6f7510e474b.jpg', alt: 'Travel photograph — stone Buddha statue' },
    { file: 'c68e20c16382a2926ab6afd9bf0fcdaa.jpg', alt: 'Travel photograph — traditional dancers' },
    { file: '2d28f907060f3ba96575343a3d41c311.jpg', alt: 'Travel photograph — local festival' },
];

// Services
const services = [
    'UGC Videos (ads & organic)', 'Voiceover Videos', 'UGC Photos',
    'Product Photography', 'On-Location Content', 'Content Bundles', 'Monthly Retainer',
];
const deliverables = [
    'Vertical format (9:16)', 'Research on branding & concepts', 'Scriptwriting',
    'Video filming & editing', '2 revisions if needed', 'Delivery in 5–7 business days',
];
---

<Layout
    title="For Brands — Maria Montserrat"
    description="Trilingual UGC creator based in Denmark — authentic, conversion-focused content in English, Spanish, and Danish for skincare, wellness, lifestyle, food, travel, and health brands."
>
    <!-- ============================ HERO ============================ -->
    <section class="relative overflow-hidden">
        <div class="absolute inset-0 -z-20 bg-sand-50"></div>

        <!-- Hero content -->
        <div class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-6 pb-24 pt-12 md:grid-cols-12 md:gap-16 md:px-10 md:pb-28 md:pt-20">
            <div class="md:col-span-6">
                <p class="fade-up flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                    UGC Creator <Langs class="text-base tracking-normal" />
                </p>
                <h1 class="fade-up-delay-1 mt-6 font-display text-5xl leading-[1.05] text-stone-900 sm:text-6xl md:text-7xl">
                    Trilingual creator. <em class="font-normal text-primary-800">Three markets.</em>
                </h1>
                <p class="fade-up-delay-2 mt-8 max-w-xl text-lg leading-relaxed text-stone-800 md:text-xl">
                    Real content that converts. I'm Maria — a content creator based in Denmark,
                    making UGC in English, Spanish, and Danish for brands that fit how I
                    actually live.
                </p>
                <p class="fade-up-delay-2 mt-4 max-w-xl text-base leading-relaxed text-stone-600">
                    Mexican-born, Denmark-based, flexitarian, dog mum (Freja&nbsp;+&nbsp;Macarena),
                    tennis &amp; padel player, Hashimoto's warrior, secondhand shopper, sun chaser.
                </p>

                <div class="fade-up-delay-3 mt-10 flex flex-col items-start gap-4 sm:flex-row sm:items-center">
                    <a href="#work-together" class="group inline-flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800">
                        Let's work together
                        <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    </a>
                    <a href="#work" class="inline-flex items-center justify-center rounded-full px-8 py-4 text-base font-semibold text-stone-900 underline-offset-4 transition hover:text-primary-800 hover:underline">
                        See my work
                    </a>
                </div>
            </div>

            <!-- Portrait -->
            <div class="fade-up-delay-2 relative md:col-span-6">
                <div class="relative mx-auto max-w-md md:max-w-none">
                    <div class="absolute -inset-4 -z-10 bg-secondary-500" style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;"></div>
                    <div class="relative overflow-hidden shadow-2xl shadow-primary-900/20" style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;">
                        <img
                            src={img('de264b56be8d0a2fb3cae44c2ad3e33c.jpg')}
                            alt="Maria Montserrat smiling outdoors"
                            class="h-[520px] w-full object-cover md:h-[620px]"
                            loading="eager"
                        />
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ============================ ABOUT ============================ -->
    <section class="relative overflow-hidden bg-white py-24 md:py-32">
        <div class="relative mx-auto grid max-w-6xl grid-cols-1 items-center gap-16 px-6 md:grid-cols-2 md:px-10">
            <div class="relative order-2 md:order-1">
                <div class="absolute -inset-3 -z-10 bg-primary-500" style="border-radius: 48% 52% 60% 40% / 56% 44% 56% 44%;"></div>
                <div class="relative overflow-hidden shadow-xl shadow-primary-900/15" style="border-radius: 48% 52% 60% 40% / 56% 44% 56% 44%;">
                    <img
                        src={img('299251c842a4cc0800fb5ed40f0b90c8.jpg')}
                        alt="Maria Montserrat seated outdoors"
                        class="h-[460px] w-full object-cover md:h-[560px]"
                        loading="lazy"
                    />
                </div>
            </div>
            <div class="order-1 md:order-2">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">About me</p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    One creator, <em class="font-normal text-primary-800">three markets</em>.
                </h2>
                <p class="mt-6 text-lg leading-relaxed text-stone-700">
                    In the last 30 days my content has reached 582K+ accounts and generated
                    1.1M+ views. I create conversion-focused UGC for skincare, wellness,
                    lifestyle, fashion, food, travel, and health brands — including autoimmune,
                    plant-based, and nervous-system-recovery niches.
                </p>
                <p class="mt-4 leading-relaxed text-stone-600">
                    My background spans teaching, journalism, yoga &amp; mindfulness instruction,
                    fashion design, and somatic practice — trained in fashion design,
                    communications, and pedagogy. My philosophy:
                    <em class="text-primary-800">give your best, not your all.</em>
                    I make content that feels real because it is.
                </p>
            </div>
        </div>
    </section>

    <!-- ============================ ANALYTICS ============================ -->
    <section class="bg-sand-100 py-20 md:py-28">
        <div class="mx-auto max-w-6xl px-6 md:px-10">
            <div class="mx-auto max-w-2xl text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">Analytics</p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    The numbers, <em class="font-normal text-primary-800">across three platforms</em>.
                </h2>
                <p class="mt-5 text-base leading-relaxed text-stone-600">
                    Reach that travels well beyond my own followers — the kind of organic
                    distribution brands are really paying for.
                </p>
            </div>

            <div class="analytics-grid mt-14 grid grid-cols-1 gap-6 md:grid-cols-3" data-analytics>
                {platforms.map((p) => {
                    return (
                        <article class="group flex flex-col overflow-hidden rounded-3xl bg-white p-8 ring-1 ring-stone-900/5 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-primary-900/10">
                            <div class="-mx-8 -mt-8 mb-7 h-2" style={`background:${BRAND[p.name].color}`}></div>

                            <header class="flex items-center justify-between gap-3">
                                <div class="flex items-center gap-2.5">
                                    <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full" style={`background:${BRAND[p.name].color}`} set:html={BRAND[p.name].svg}></span>
                                    <p class="text-sm font-semibold text-stone-900">{p.name}</p>
                                </div>
                                <span class="rounded-full bg-sand-100 px-2.5 py-1 text-[11px] font-medium text-stone-500">{p.period}</span>
                            </header>

                            <div class="mt-8">
                                <span class="stat-count font-display text-6xl leading-none text-primary-800" {...countAttrs(p.headline.value)}>{p.headline.value}</span>
                                <div class="mt-3 flex items-center gap-2">
                                    <p class="text-sm font-medium text-stone-700">{p.headline.label}</p>
                                    <span class:list={["inline-flex items-center gap-0.5 rounded-full px-2 py-0.5 text-xs font-semibold", p.headline.delta >= 0 ? "bg-emerald-50 text-emerald-700" : "bg-rose-50 text-rose-600"]}>
                                        <svg width="10" height="10" viewBox="0 0 20 20" fill="currentColor">{p.headline.delta >= 0 ? <path d="M10 4l6 8H4z"/> : <path d="M10 16l-6-8h12z"/>}</svg>
                                        {Math.abs(p.headline.delta)}%
                                    </span>
                                </div>
                                <p class="mt-1.5 text-xs text-stone-400">= {p.headline.long} {p.headline.label.toLowerCase()}</p>
                            </div>

                            <hr class="mt-7 border-stone-100" />

                            <dl class="mt-5 grid grid-cols-2 gap-x-4 gap-y-5">
                                {p.metrics.map((m) => (
                                    <div>
                                        <dt class="text-xs text-stone-500">{m.label}</dt>
                                        <dd class="mt-1 flex items-baseline gap-1.5">
                                            <span class="stat-count font-display text-2xl text-stone-900" {...countAttrs(m.value)}>{m.value}</span>
                                            <span class:list={["inline-flex items-center text-[11px] font-semibold", m.delta >= 0 ? "text-emerald-700" : "text-rose-600"]}>
                                                <svg width="9" height="9" viewBox="0 0 20 20" fill="currentColor">{m.delta >= 0 ? <path d="M10 4l6 8H4z"/> : <path d="M10 16l-6-8h12z"/>}</svg>
                                                {Math.abs(m.delta)}%
                                            </span>
                                        </dd>
                                    </div>
                                ))}
                            </dl>

                            {p.newAudience != null && (
                                <div class="mt-7 flex items-center gap-4">
                                    <div class="relative h-20 w-20 shrink-0">
                                        <svg viewBox="0 0 40 40" class="h-20 w-20 -rotate-90">
                                            <circle cx="20" cy="20" r="16" fill="none" stroke-width="3.5" style="stroke: var(--color-sand-300)" />
                                            <circle class="gauge-fill" cx="20" cy="20" r="16" fill="none" stroke-width="3.5" stroke-linecap="butt" pathLength="100" stroke-dasharray="100" stroke-dashoffset={100 - p.newAudience} data-gauge-off={100 - p.newAudience} style="stroke: var(--color-primary-600)" />
                                        </svg>
                                        <div class="absolute inset-0 flex items-center justify-center">
                                            <span class="stat-count text-sm font-semibold leading-none text-primary-800" {...countAttrs(`${p.newAudience}%`)}>{p.newAudience}%</span>
                                        </div>
                                    </div>
                                    <p class="text-sm leading-snug text-stone-600">
                                        of reach comes from <span class="font-semibold text-stone-800">people who don't follow her yet</span>
                                    </p>
                                </div>
                            )}

                            {p.highlight && (
                                <div class="mt-7 flex items-center gap-4 rounded-2xl bg-sand-50 p-4">
                                    <span class="stat-count font-display text-4xl leading-none text-primary-800" {...countAttrs(p.highlight.stat)}>{p.highlight.stat}</span>
                                    <p class="text-sm leading-snug text-stone-600">{p.highlight.text}</p>
                                </div>
                            )}

                            <a href={p.url} target="_blank" rel="noopener noreferrer" class="mt-auto inline-flex items-center gap-1 pt-7 text-sm font-medium text-stone-700 underline-offset-4 transition hover:text-primary-800 hover:underline">
                                {p.handle}
                                <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
                            </a>
                        </article>
                    );
                })}
            </div>

            <p class="mt-8 text-center text-xs text-stone-400">
                Self-reported figures from each platform's own analytics · snapshot {analyticsUpdated}
            </p>
        </div>
    </section>

    <!-- ============================ HOW I SHOW UP (reels) ============================ -->
    <section id="work" class="relative overflow-hidden bg-white py-24 md:py-32">
        <div class="relative mx-auto max-w-6xl px-6 md:px-10">
            <div class="mx-auto max-w-2xl text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">How I show up</p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    Organic reels, <em class="font-normal text-primary-800">real moments</em>.
                </h2>
                <p class="mt-6 text-lg leading-relaxed text-stone-700">
                    Personal-brand storytelling around burnout, the nervous system, and finding
                    your way back to yourself — the content that builds the trust brands borrow.
                </p>
            </div>
            <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
                {reels.map((r) => (
                    <article class="group flex flex-col overflow-hidden rounded-3xl bg-sand-50 ring-1 ring-stone-900/5 transition hover:shadow-lg hover:shadow-primary-900/8">
                        <div class="bv group/video relative aspect-[9/16] bg-primary-500">
                            <video
                                src={vid(r.video)}
                                class="bv-video h-full w-full object-cover"
                                autoplay
                                muted
                                loop
                                playsinline
                                preload="metadata"
                                aria-label={r.title}
                            ></video>
                            <div class="bv-controls absolute bottom-3 left-3 z-10 flex gap-2 opacity-0 transition focus-within:opacity-100 group-hover/video:opacity-100">
                                <button type="button" class="bv-toggle grid h-10 w-10 place-items-center rounded-full bg-stone-900/45 text-white backdrop-blur-sm transition hover:bg-stone-900/65" aria-label="Play or pause video">
                                    <svg class="bv-icon-play hidden h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M6 4l10 6-10 6V4z"/></svg>
                                    <svg class="bv-icon-pause h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M6 4h3v12H6zM11 4h3v12h-3z"/></svg>
                                </button>
                                <button type="button" class="bv-mute grid h-10 w-10 place-items-center rounded-full bg-stone-900/45 text-white backdrop-blur-sm transition hover:bg-stone-900/65" aria-label="Mute or unmute video">
                                    <svg class="bv-icon-muted h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
