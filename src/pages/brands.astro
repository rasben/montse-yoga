<script>
    // Controls for the autoplaying, muted brand videos. Each clip:
    //  - autoplays muted + looped, but only while it's on screen (saves the
    //    browser from decoding all nine at once) via an IntersectionObserver;
    //  - has a play/pause toggle (clicking the video works too). A manual pause
    //    is remembered, so scrolling away and back won't auto-resume it;
    //  - has a mute/unmute toggle. Icons stay in sync with the real state.
    document.querySelectorAll<HTMLVideoElement>('video.bv-video').forEach((video) => {
        const wrap = video.closest('.bv');
        if (!wrap) return;
        const toggleBtn = wrap.querySelector('.bv-toggle');
        const muteBtn = wrap.querySelector('.bv-mute');
        const iconPlay = wrap.querySelector('.bv-icon-play');
        const iconPause = wrap.querySelector('.bv-icon-pause');
        const iconMuted = wrap.querySelector('.bv-icon-muted');
        const iconUnmuted = wrap.querySelector('.bv-icon-unmuted');

        let userPaused = false;

        const syncPlay = () => {
            const playing = !video.paused && !video.ended;
            iconPlay?.classList.toggle('hidden', playing);
            iconPause?.classList.toggle('hidden', !playing);
        };
        const syncMute = () => {
            iconMuted?.classList.toggle('hidden', !video.muted);
            iconUnmuted?.classList.toggle('hidden', video.muted);
        };

        toggleBtn?.addEventListener('click', () => {
            if (video.paused) {
                userPaused = false;
                video.play().catch(() => {});
            } else {
                userPaused = true;
                video.pause();
            }
        });
        video.addEventListener('click', () => toggleBtn?.dispatchEvent(new Event('click')));
        muteBtn?.addEventListener('click', () => {
            video.muted = !video.muted;
            syncMute();
        });
        video.addEventListener('play', syncPlay);
        video.addEventListener('pause', syncPlay);

        // Only play while a meaningful part of the clip is in view; pause otherwise.
        const io = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        if (!userPaused) video.play().catch(() => {});
                    } else {
                        video.pause();
                    }
                }
            },
            { threshold: 0.25 },
        );
        io.observe(video);

        syncPlay();
        syncMute();
    });
</script>

<script>
    // Scroll-triggered animation for the analytics cards — runs once, when the
    // section enters view. Everything is driven from JS (the gauge included, via
    // inline stroke-dashoffset) so it doesn't depend on scoped CSS reaching the
    // SVG. Honours prefers-reduced-motion. Without JS, the markup already shows
    // its finished state (real numbers, filled gauges), so it degrades cleanly.
    const grid = document.querySelector<HTMLElement>('[data-analytics]');
    if (grid) {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        // Calm easing: gentle start, the bigger leaps land in the middle, soft finish.
        const easeInOut = (t: number) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

        const fmt = (n: number, dec: number, suffix: string, sep: boolean) => {
            const rounded = dec > 0 ? Number(n.toFixed(dec)) : Math.round(n);
            const base = sep
                ? rounded.toLocaleString('en-US')
                : dec > 0
                  ? rounded.toFixed(dec)
                  : String(rounded);
            return base + suffix;
        };

        const read = (el: HTMLElement) => ({
            to: parseFloat(el.dataset.countTo || '0'),
            dec: parseInt(el.dataset.countDecimals || '0', 10),
            suffix: el.dataset.countSuffix || '',
            sep: el.dataset.countSep === '1',
        });

        const counts = [...grid.querySelectorAll<HTMLElement>('.stat-count')];
        const gauges = [...grid.querySelectorAll<SVGCircleElement>('.gauge-fill')];

        if (!reduce) {
            // Arm: zero the numbers and empty the gauges so they have room to fill.
            counts.forEach((el) => {
                const c = read(el);
                el.textContent = fmt(0, c.dec, c.suffix, c.sep);
            });
            gauges.forEach((el) => {
                el.style.strokeDashoffset = '100';
            });
        }

        // Stepped count-up: ~16 discrete leaps over 2s reads calmer than a smooth
        // 60fps blur, and lets the eased middle steps take the bigger jumps.
        const animateCount = (el: HTMLElement, delay: number) => {
            const c = read(el);
            const steps = 16;
            const stepMs = 125;
            let step = 0;
            window.setTimeout(() => {
                const tick = () => {
                    step += 1;
                    const eased = easeInOut(step / steps);
                    el.textContent = fmt(c.to * eased, c.dec, c.suffix, c.sep);
                    if (step < steps) window.setTimeout(tick, stepMs);
                    else el.textContent = fmt(c.to, c.dec, c.suffix, c.sep);
                };
                tick();
            }, delay);
        };

        // Gauge sweep: animate the ring's stroke-dashoffset from empty (100) to its
        // target (100 − percent) so the arc visibly draws around the circle.
        const animateGauge = (el: SVGCircleElement, delay: number) => {
            const target = parseFloat(el.dataset.gaugeOff || '0');
            const duration = 1700;
            window.setTimeout(() => {
                const start = performance.now();
                const tick = (now: number) => {
                    const t = Math.min(1, (now - start) / duration);
                    el.style.strokeDashoffset = String(100 + (target - 100) * easeInOut(t));
                    if (t < 1) requestAnimationFrame(tick);
                    else el.style.strokeDashoffset = String(target);
                };
                requestAnimationFrame(tick);
            }, delay);
        };

        const run = () => {
            if (reduce) return;
            [...grid.querySelectorAll('article')].forEach((article, i) => {
                const delay = i * 160;
                article.querySelectorAll<HTMLElement>('.stat-count').forEach((el) => animateCount(el, delay));
                article.querySelectorAll<SVGCircleElement>('.gauge-fill').forEach((el) => animateGauge(el, delay));
            });
        };

        const io = new IntersectionObserver(
            (entries, obs) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) {
                        run();
                        obs.disconnect();
                    }
                }
            },
            { threshold: 0.2 },
        );
        io.observe(grid);
    }
</script>
