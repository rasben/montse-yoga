---
// Homepage — thin wrapper around HomeBody. Three sibling files exist:
//   src/pages/index.astro       (English, served at /)
//   src/pages/es/index.astro    (Spanish, served at /es/)
//   src/pages/da/index.astro    (Danish,  served at /da/)
// They all render the same HomeBody — Astro's i18n routing fills in the
// locale, and the body reads its copy from src/i18n/ui.ts via useTranslations.
import Layout from '../layouts/Layout.astro';
import HomeBody from '../components/pages/HomeBody.astro';
---

<Layout pageKey="home">
    <HomeBody />
</Layout>
