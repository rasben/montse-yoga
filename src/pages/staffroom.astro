---
// "The Staffroom" — monthly membership sales page for teachers.
// This is the "For teachers" destination in the global Header nav.
// Route: /staffroom (replaced the old generic /teacher-yoga offerings page,
// which has been removed — see AGENTS.md).
//
// Copy is Maria's, provided in full and used close to verbatim — this file
// is primarily concerned with layout, not rewriting her words. Deliberately
// avoids the word "burnout" throughout, per her instruction (see AGENTS.md
// "Voice notes for copy" under The Staffroom).
//
// Images are pulled from Maria's Canva ("Maria _ The staffroom", "The
// Staffroom header", "the staffroom logo", "Testimonials - Maria website")
// and saved locally to src/assets/staffroom/.
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import maria from '../assets/staffroom/staffroom-hero.png';
import staffroomHeader from '../assets/staffroom/staffroom-header.png';
import staffroomLogo from '../assets/staffroom/staffroom-logo.png';
import staffroomTestimonials from '../assets/staffroom/staffroom-testimonials.png';

// Same Skool link for both — free and paid tiers are both reached from
// the community's /about page (confirmed with Maria 2026-07-17).
const CHECKOUT_URL = 'https://www.skool.com/thestaffroom/about';
const SKOOL_FREE_URL = CHECKOUT_URL;

const promises = [
    'You know what your body has been trying to tell you for years.',
    'You know whether you want to stay, make changes, or go — and you understand why, for the first time.',
    'You stop carrying the belief that the problem is you.',
    'You stop spending Sunday evenings dreading Monday. Not because Monday changes. Because you do.',
    'You understand who you are outside the role. Not after you leave. Now.',
    'You have a space that already gets it — where you never have to explain why a holiday doesn’t fix it.',
    'You stop living only on holiday.',
];

const features = [
    {
        emoji: '\u{1F4D3}',
        title: '8 weeks of weekly teachings',
        body: 'Teachings, body practices, and reflection prompts you can move through at your own pace — twenty minutes if that’s all you have. The body practices are there because clarity doesn’t come from thinking harder. It comes from listening to what’s already in your body. The prompts are there to help you hear it.',
    },
    {
        emoji: '\u{1F4DE}',
        title: 'Live calls every two weeks',
        body: 'Somewhere to bring what comes up, without carrying it alone. Being heard by someone who already knows the feeling — and a room full of people who do too. This is the part that changes the most.',
    },
    {
        emoji: '\u{1F91D}',
        title: 'A community that already gets it',
        body: 'No “have you tried a different school?” No “you’re so lucky to have that job.” Just people who are in the same place — and figuring out who they are on the other side.',
    },
    {
        emoji: '\u{1F331}',
        title: 'Monthly practices after week 8',
        body: 'This doesn’t end in 8 weeks. You don’t finish The Staffroom — you keep using it. The point isn’t to complete a programme. It’s a relationship with yourself that doesn’t disappear when the structure does.',
    },
];

const faqs = [
    {
        q: '“I don’t have time. I’m already exhausted.”',
        a: 'The Staffroom is designed for exactly this. Twenty minutes at a time. On your own schedule. In the car park after school if that’s the only quiet moment you have. You don’t need more hours in your week — you need to use a few of them on this instead of on something that isn’t working. The practices work best in small doses anyway. Your body needs space, not marathons.',
    },
    {
        q: '“I’ve tried things like this before and nothing changed.”',
        a: 'Most things treat the outside: different strategies, better limits, new habits. This goes to the part that hasn’t changed no matter what you’ve tried — because the job was never the real problem. The first seven days are free. You can feel the difference for yourself before you commit.',
    },
    {
        q: '“Is this going to tell me I should quit?”',
        a: 'No. The Staffroom isn’t about leaving. It’s about knowing who you are whether you stay or go. What you do with that clarity is yours. You can go through The Staffroom and choose to stay — and show up completely differently because of it.',
    },
    {
        q: '“I’ve done everything right — the books, the yoga, the courses, the leave. Nothing actually changed. Why would this be different?”',
        a: 'Because everything you’ve tried has been aimed at the outside. A different school, better habits, more rest, a good summer — they treat the symptoms. The flat feeling isn’t coming from the outside. It’s coming from the part of you that has been signalling something for years that you’ve learned to override. The Staffroom goes there directly. Not to help you cope better with the current situation. To help you hear what the situation has been trying to tell you.',
    },
    {
        q: '“I’m not sure I’m ready.”',
        a: 'You don’t have to be ready. You have to be tired enough of the current answer. You don’t need to be certain. You just need to be curious enough to try.',
    },
    {
        q: '“What if I can’t make the live calls?”',
        a: 'All calls are recorded and available inside the community. You can also send questions in advance if you know you can’t be there live. You won’t miss the session just because you couldn’t attend it in real time.',
    },
];
---

<Layout
    title="The Staffroom — A Monthly Membership for Teachers | Maria Montserrat"
    description="The Staffroom is a monthly membership for teachers who are still showing up on the outside while quietly disappearing on the inside. Weekly practices, live calls every two weeks, and a community that already gets it."
    image="/og-staffroom.jpg"
>
    <!-- ============================ SECTION 1 — HERO ============================ -->
    <section class="relative overflow-hidden">
        <div class="absolute inset-0 -z-20 bg-primary-100"></div>

        <div class="relative z-10 mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 px-6 pb-16 pt-14 md:grid-cols-12 md:gap-16 md:px-10 md:pb-20 md:pt-20">
            <div class="md:col-span-6">
                <p class="fade-up flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                    <img src={staffroomLogo.src} alt="" class="h-6 w-6 rounded-full shadow-sm" />
                    The Staffroom &middot; A monthly membership for teachers
                </p>
                <h1 class="fade-up-delay-1 mt-6 font-display text-4xl leading-[1.1] text-stone-900 sm:text-5xl md:text-6xl">
                    You’re still showing up. <em class="font-normal text-primary-800">But you stopped being there.</em>
                </h1>
                <p class="fade-up-delay-2 mt-8 max-w-xl text-lg leading-relaxed text-stone-800 md:text-xl">
                    The Staffroom is a monthly membership for teachers who are still performing
                    fine on the outside — and quietly disappearing on the inside.
                </p>

                <div class="fade-up-delay-3 mt-8 max-w-xl rounded-2xl bg-white/70 p-5 text-sm leading-relaxed text-stone-700 ring-1 ring-stone-900/5 backdrop-blur-sm">
                    This is not for teachers in crisis. It’s for the ones who are still going,
                    still smiling at parents’ evening, still marking at 9pm — who sit somewhere
                    quiet afterwards and think: <em class="text-primary-800">is this it?</em>
                </div>

                <div class="fade-up-delay-3 mt-10">
                    <a
                        href="#join"
                        class="group inline-flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800"
                    >
                        Join the founding month
                        <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                    </a>
                    <p class="mt-3 text-sm font-medium text-stone-600">€57/month &middot; first 7 days free</p>
                </div>
            </div>

            <div class="fade-up-delay-2 relative md:col-span-6">
                <div class="relative mx-auto max-w-md md:max-w-none">
                    <div class="absolute -inset-4 -z-10 bg-accent-500" style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;"></div>
                    <div class="relative overflow-hidden shadow-2xl shadow-primary-900/20" style="border-radius: 62% 38% 56% 44% / 48% 60% 40% 52%;">
                        <Image
                            src={maria}
                            alt="Maria Montserrat smiling, seated, warm and grounded"
                            widths={[480, 720, 960]}
                            sizes="(min-width: 768px) 50vw, 90vw"
                            class="h-[480px] w-full object-cover md:h-[580px]"
                            loading="eager"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- Header banner (Maria's "You are Your Calling / The Staffroom" Canva banner) -->
        <div class="relative z-10 mx-auto max-w-5xl px-6 pb-16 md:px-10">
            <div class="overflow-hidden rounded-3xl shadow-lg shadow-primary-900/15">
                <Image
                    src={staffroomHeader}
                    alt="You are Your Calling — The Staffroom"
                    widths={[600, 900, 1084]}
                    sizes="(min-width: 768px) 900px, 90vw"
                    class="h-auto w-full object-cover"
                    loading="eager"
                />
            </div>
        </div>
    </section>

    <!-- ============================ SECTION 2 — THE PROMISE ============================ -->
    <section class="bg-white py-24 md:py-32">
        <div class="mx-auto max-w-4xl px-6 md:px-10">
            <div class="mx-auto max-w-2xl text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">After The Staffroom</p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    What actually <em class="font-normal text-primary-800">changes</em>.
                </h2>
            </div>

            <ul class="mt-14 space-y-5">
                {promises.map((p) => (
                    <li class="flex items-start gap-4 rounded-2xl bg-sand-50 p-5 ring-1 ring-stone-900/5">
                        <svg class="mt-1 h-5 w-5 shrink-0 text-primary-700" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        <p class="text-lg leading-relaxed text-stone-800">{p}</p>
                    </li>
                ))}
            </ul>
        </div>
    </section>

    <!-- ============================ SECTION 3 — PAIN → RELIEF ============================ -->
    <section class="relative overflow-hidden bg-secondary-100 py-24 md:py-32">
        <div class="mx-auto max-w-3xl px-6 md:px-10">
            <p class="fade-up text-center font-display text-2xl italic leading-relaxed text-stone-900 sm:text-3xl">
                You’ve been performing fine for so long you’ve forgotten what being real feels like.
            </p>

            <div class="mt-10 space-y-6 text-lg leading-relaxed text-stone-700">
                <p>
                    You might haven’t had a breakdown. Or maybe you went on stress leave, came
                    back and still…
                </p>
                <p>
                    You show up. You answer the emails. You’re good at this.
                    And nobody sees the part that’s disappearing.
                </p>
                <p>
                    You’ve tried to fix it. A different school. Fewer hours. A better summer.
                    The books you almost finished. The journals you kept for two weeks. The
                    courses you bought on a hard evening and opened twice.
                </p>
                <p class="font-semibold text-stone-900">The feeling followed you.</p>
                <p>
                    So you’ve started to wonder if the problem is you. That you’re not strong
                    enough for a normal life. That other people manage somehow — and you’re
                    the one who can’t keep up. That doing everything right — the yoga, the
                    journalling, the leave, the changes — and still feeling flat means
                    something is fundamentally wrong with you.
                </p>
                <p class="font-display text-2xl italic text-primary-800">It doesn’t.</p>
                <p>
                    Not in the way you’ve been thinking. Not the broken version of you.
                    The buried one. The one who got quieter and quieter because there was
                    never any room for her.
                </p>
                <p>
                    You’ve been blaming yourself for a signal you were trained not to hear.
                    Not because you’re weak. Not because the job is wrong. Not because you
                    chose badly.
                </p>
                <p>Because the thing that needs attention isn’t out there.</p>
                <p class="font-semibold text-stone-900">It’s in here. And nobody has ever asked you to listen to it.</p>
            </div>

            <div class="mt-16 rounded-3xl bg-white p-8 ring-1 ring-stone-900/5 md:p-10">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">Here’s what’s actually happening</p>
                <p class="mt-4 text-lg leading-relaxed text-stone-700">
                    When you give everything — for years, to 28 students a day, to a system
                    that never stops asking — the part of you that knows what you need gets
                    quieter and quieter. Not gone. Just very good at being ignored.
                </p>
                <p class="mt-6 font-display text-3xl leading-snug text-stone-900">
                    The flat feeling isn’t a flaw. <em class="font-normal text-primary-800">It’s a signal.</em>
                </p>
                <p class="mt-6 text-lg leading-relaxed text-stone-700">
                    You don’t need to have the answers. You don’t need to have decided
                    anything. You need to hear yourself again.
                </p>
                <p class="mt-4 font-semibold text-stone-900">That’s what The Staffroom is for.</p>
            </div>
        </div>
    </section>

    <!-- ============================ SECTION 4 — FEATURES → BENEFITS ============================ -->
    <section class="bg-white py-24 md:py-32">
        <div class="mx-auto max-w-6xl px-6 md:px-10">
            <div class="mx-auto max-w-2xl text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">How it works</p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    Structure that holds you, <em class="font-normal text-primary-800">without pressure</em>.
                </h2>
            </div>

            <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2">
                {features.map((f) => (
                    <article class="rounded-3xl bg-sand-50 p-8 ring-1 ring-stone-900/5">
                        <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary-100 text-2xl">
                            {f.emoji}
                        </div>
                        <h3 class="font-display text-2xl text-stone-900">{f.title}</h3>
                        <p class="mt-3 leading-relaxed text-stone-700">{f.body}</p>
                    </article>
                ))}
            </div>

            <div class="mt-14 rounded-3xl bg-primary-700 p-8 text-white md:p-10">
                <h3 class="font-display text-2xl">This is for you if…</h3>
                <p class="mt-4 max-w-3xl leading-relaxed text-primary-50">
                    This is for you if you’ve tried the leave, the change of school, the
                    books, the journalling — and still come home flat. You’ve been telling
                    yourself you’re just tired for longer than you can remember. You’ve
                    started to wonder whether the problem is you.
                </p>
                <p class="mt-4 max-w-3xl font-display text-xl italic text-white">
                    It isn’t. But you won’t believe that until you hear yourself again.
                </p>
            </div>
        </div>
    </section>

    <!-- ============================ SECTION 5 — CREDIBILITY ============================ -->
    <section class="relative overflow-hidden bg-accent-100 py-24 md:py-32">
        <div class="relative mx-auto max-w-4xl px-6 text-center md:px-10">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">Why me</p>
            <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                Maria Montserrat.
            </h2>
            <div class="mx-auto mt-8 max-w-2xl space-y-5 text-left text-lg leading-relaxed text-stone-700">
                <p>
                    I spent six years in classrooms across two countries. I went through two
                    kinds of exhaustion — the crash (panic attacks, a month home, back before
                    I was ready because I felt guilty for leaving) and the flat (still showing
                    up, still functional, just slowly disappearing).
                </p>
                <p>
                    The flat one scared me more. Nobody sees the flat one. You can’t explain
                    it. And you start to wonder if you’re imagining it.
                </p>
                <p>
                    I left without a plan. I flew to India and got certified as a yoga
                    instructor. Not because I had a strategy. Because I needed to find out
                    who I was when nobody needed anything from me.
                </p>
                <p>
                    I’m a certified yoga instructor, mindfulness coach, and nervous system
                    practitioner. I built The Staffroom because this space didn’t exist when
                    I needed it. Not a course to get through. Not a community where you
                    perform being okay. A place to do the actual work, on your own timeline,
                    with support that doesn’t disappear.
                </p>
                <p class="font-display text-xl italic leading-snug text-primary-800">
                    I’m not here from a mountaintop. I’m one step ahead. And I remember
                    exactly what the flat felt like.
                </p>
                <p class="text-stone-600">
                    And I remember blaming myself for it. For years.
                </p>
            </div>
        </div>
    </section>

    <!-- ============================ SECTION 6 — SOCIAL PROOF ============================ -->
    <section class="bg-white py-24 md:py-32">
        <div class="mx-auto max-w-4xl px-6 text-center md:px-10">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">What teachers say</p>
            <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                What teachers say when they finally <em class="font-normal text-primary-800">have words for it</em>.
            </h2>

            <div class="mt-12 overflow-hidden rounded-3xl shadow-lg shadow-primary-900/10 ring-1 ring-stone-900/5">
                <Image
                    src={staffroomTestimonials}
                    alt="Screenshots of messages and comments from teachers responding to Maria's content"
                    widths={[600, 900, 1366]}
                    sizes="(min-width: 768px) 900px, 90vw"
                    class="h-auto w-full object-cover"
                    loading="lazy"
                />
            </div>

            <p class="mx-auto mt-8 max-w-xl text-sm leading-relaxed text-stone-500">
                These are from teachers who found this work through my content and courses.
                The Staffroom is new. What it’s built from is not.
            </p>
        </div>
    </section>

    <!-- ============================ SECTION 7 — FAQ ============================ -->
    <section class="bg-sand-50 py-24 md:py-32">
        <div class="mx-auto max-w-3xl px-6 md:px-10">
            <div class="mx-auto max-w-2xl text-center">
                <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">Questions</p>
                <h2 class="mt-4 font-display text-4xl leading-tight text-stone-900 sm:text-5xl">
                    Before you join.
                </h2>
            </div>

            <div class="mt-14 space-y-4">
                {faqs.map((item) => (
                    <details class="group rounded-2xl bg-white p-6 ring-1 ring-stone-900/5 open:shadow-sm">
                        <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-xl text-stone-900 marker:hidden">
                            <span>{item.q}</span>
                            <svg class="h-5 w-5 shrink-0 text-primary-700 transition group-open:rotate-45" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z" clip-rule="evenodd"/></svg>
                        </summary>
                        <p class="mt-4 leading-relaxed text-stone-700">{item.a}</p>
                    </details>
                ))}
            </div>
        </div>
    </section>

    <!-- ============================ SECTION 8 — FINAL CTA ============================ -->
    <section id="join" class="relative overflow-hidden bg-secondary-800 py-24 md:py-32">
        <div class="absolute inset-0 -z-10 opacity-20" aria-hidden="true">
            <div class="absolute -left-20 top-10 h-72 w-72 rounded-full bg-accent-500 blur-3xl"></div>
            <div class="absolute -right-20 bottom-10 h-80 w-80 rounded-full bg-primary-500 blur-3xl"></div>
        </div>

        <div class="relative mx-auto max-w-3xl px-6 text-center md:px-10">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-accent-300">The version of you who knows what she needs</p>
            <h2 class="mt-6 font-display text-4xl leading-tight text-white sm:text-5xl md:text-6xl">
                She’s not a future version. <em class="font-normal text-accent-300">She’s already in there.</em>
            </h2>
            <div class="mx-auto mt-8 max-w-xl space-y-4 text-lg leading-relaxed text-secondary-100">
                <p>
                    She got quieter when things got heavy. She stopped asking for attention
                    when there wasn’t room for her. She got very good at being fine.
                </p>
                <p>She started to think the problem was her.</p>
                <p class="font-semibold text-white">The Staffroom is where you start listening to her again.</p>
                <p>
                    The signal doesn’t disappear once you start hearing it. Life keeps being
                    loud. The Staffroom is the place you come back to — every month — when the
                    noise gets heavy again.
                </p>
            </div>

            <!-- Pricing card -->
            <div class="mx-auto mt-12 max-w-lg rounded-3xl bg-white p-8 text-left shadow-xl md:p-10">
                <p class="text-xs font-semibold uppercase tracking-[0.3em] text-primary-800">Founding month &middot; July 2026</p>
                <p class="mt-4 font-display text-5xl text-stone-900">€57<span class="text-xl font-sans font-normal text-stone-500">/month</span></p>
                <p class="mt-2 text-sm text-stone-600">Locked in at this price forever if you join in July.</p>
                <p class="mt-1 text-sm text-stone-600">From August 1: €77/month.</p>
                <p class="mt-4 text-sm font-semibold text-stone-900">First 7 days free. Full refund in the first 7 days, no questions asked.</p>
                <p class="mt-1 text-xs text-stone-500">No minimum commitment. Cancel anytime.</p>

                <a
                    href={CHECKOUT_URL}
                    class="group mt-8 flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800"
                >
                    Join the founding month
                    <svg class="ml-2 h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>
            </div>

            <!-- Not ready yet? — free tier on Skool -->
            <div class="mx-auto mt-10 max-w-lg border-t border-white/15 pt-10 text-left">
                <p class="font-display text-2xl text-white">Not ready yet?</p>
                <p class="mt-4 leading-relaxed text-secondary-100">
                    The free community is where you find out you’re not alone. The full
                    membership is where you find out who you actually are.
                </p>
                <p class="mt-3 leading-relaxed text-secondary-100">
                    You can join The Staffroom free — the community, the guide, and the
                    essays — and feel what the space is like before you decide to go deeper.
                </p>
                <a
                    href={SKOOL_FREE_URL}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group mt-6 inline-flex items-center gap-2 text-base font-semibold text-white underline-offset-4 transition hover:underline"
                >
                    Start free
                    <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>
            </div>
        </div>
    </section>
</Layout>

<style>
    /* Hide the default summary triangle in browsers that still show it. */
    details > summary {
        list-style: none;
    }
    details > summary::-webkit-details-marker {
        display: none;
    }
</style>
