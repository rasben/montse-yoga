---
import Layout from '../layouts/Layout.astro';
import courses from '../data/courses.json';
---

<Layout title="Online Courses — Maria Montserrat" description="Self-paced yoga and mindfulness courses for teachers, carers, and anyone moving beyond burnout. Practice anywhere, at your own pace.">
    <!-- Page hero -->
    <section class="relative overflow-hidden">
        <div class="absolute inset-0 -z-20 bg-gradient-to-br from-sand-50 via-primary-50 to-secondary-50"></div>
        <div class="blob float-slow bg-primary-200" style="width: 420px; height: 420px; top: -100px; right: -80px;"></div>
        <div class="blob float-slower bg-secondary-200" style="width: 300px; height: 300px; bottom: -80px; left: -80px;"></div>

        <!-- Nav -->
        <nav class="relative z-10 mx-auto flex max-w-7xl items-center justify-between px-6 pt-6 md:px-10 md:pt-8">
            <a href="/" class="inline-flex items-center gap-2 text-sm font-semibold text-stone-700 transition hover:text-primary-800">
                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"/></svg>
                Back to home
            </a>
            <a
                href="#contact-courses"
                class="inline-flex items-center rounded-full border border-primary-700 bg-white/80 px-5 py-2 text-sm font-semibold text-primary-800 shadow-sm backdrop-blur-sm transition hover:bg-primary-700 hover:text-white"
            >
                Get in touch
            </a>
        </nav>

        <!-- Hero copy -->
        <div class="relative z-10 mx-auto max-w-3xl px-6 pb-24 pt-16 text-center md:px-10 md:pb-28 md:pt-20">
            <p class="text-xs font-semibold uppercase tracking-[0.35em] text-primary-800">
                For teachers &middot; Carers &middot; Helping professionals
            </p>
            <h1 class="mt-6 font-display text-5xl leading-[1.05] text-stone-900 sm:text-6xl md:text-7xl">
                Practice on <em class="font-normal text-primary-800">your schedule</em>.
            </h1>
            <p class="mx-auto mt-8 max-w-xl text-lg leading-relaxed text-stone-700">
                Self-paced courses built for people who give a lot to others. Work through them
                at home, at your own pace — no mat required for most, no prior yoga experience needed.
            </p>
        </div>
    </section>

    <!-- Course grid -->
    <section class="bg-white py-16 md:py-24">
        <div class="mx-auto max-w-6xl px-6 md:px-10">
            {courses.length > 0 ? (
                <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
                    {courses.map((course) => (
                        <a
                            href={course.url}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group flex flex-col overflow-hidden rounded-3xl bg-sand-50 ring-1 ring-stone-900/5 shadow-sm transition hover:shadow-xl hover:shadow-primary-900/10 hover:-translate-y-1"
                        >
                            <!-- Thumbnail -->
                            {course.image ? (
                                <div class="h-52 w-full overflow-hidden bg-sand-200">
                                    <img
                                        src={course.image}
                                        alt={course.title}
                                        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                                        loading="lazy"
                                    />
                                </div>
                            ) : (
                                <div class="flex h-52 w-full items-center justify-center bg-gradient-to-br from-primary-100 to-secondary-100 text-5xl">
                                    🎓
                                </div>
                            )}

                            <!-- Content -->
                            <div class="flex flex-1 flex-col p-7">
                                <h2 class="font-display text-2xl leading-snug text-stone-900 transition group-hover:text-primary-800">
                                    {course.title}
                                </h2>

                                {course.description && (
                                    <p class="mt-3 flex-1 text-base leading-relaxed text-stone-600">
                                        {course.description}
                                    </p>
                                )}

                                <div class="mt-6 flex items-center justify-between">
                                    {course.price ? (
                                        <span class={`rounded-full px-3 py-1 text-sm font-semibold ${course.price === 'FREE' ? 'bg-secondary-100 text-secondary-800' : 'bg-primary-100 text-primary-800'}`}>
                                            {course.price}
                                        </span>
                                    ) : <span />}
                                    <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary-700 transition group-hover:text-primary-800">
                                        View course
                                        <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M10.293 4.293a1 1 0 011.414 0l5 5a1 1 0 010 1.414l-5 5a1 1 0 01-1.414-1.414L13.586 11H4a1 1 0 110-2h9.586l-3.293-3.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            ) : (
                <p class="text-center text-stone-500">Courses coming soon — check back shortly.</p>
            )}
        </div>
    </section>

    <!-- Minimal contact nudge -->
    <section id="contact-courses" class="bg-sand-100 py-20 md:py-24">
        <div class="mx-auto max-w-2xl px-6 text-center md:px-10">
            <h2 class="font-display text-3xl text-stone-900 sm:text-4xl">
                Not sure which course is right for you?
            </h2>
            <p class="mt-5 text-lg leading-relaxed text-stone-700">
                Reach out — Maria reads every message herself and is happy to point you
                in the right direction.
            </p>
            <a
                href="mailto:maria@maria-montserrat.com"
                class="mt-8 inline-flex items-center justify-center rounded-full bg-primary-700 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-primary-700/30 transition hover:bg-primary-800"
            >
                Send a message
            </a>
            <p class="mt-6 text-sm text-stone-500">
                Or <a href="/" class="underline underline-offset-4 hover:text-primary-800 transition">return to the home page</a>.
            </p>
        </div>
    </section>
</Layout>
