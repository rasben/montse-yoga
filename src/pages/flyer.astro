---
import Layout from "../layouts/Layout.astro";
import { Heading, Spinner } from "flowbite-svelte";

// Where the flyer QR code lands: Maria's Canva site. Shared with the
// redirect script below via define:vars.
const WEB_URL = "https://maria-montserrat.my.canva.site/";
---

<script is:inline define:vars={{ WEB_URL }}>
    // Replace this with your actual numeric ID
    const PAGE_ID = "61585999057635";

    // The "Deep Link" formats
    const iosAppUrl = `fb://page/?id=${PAGE_ID}&sk=events`;
    const androidAppUrl = `fb://page/${PAGE_ID}/events`;

    function openEvents() {
        const isAndroid = /Android/i.test(navigator.userAgent);
        const appUrl = isAndroid ? androidAppUrl : iosAppUrl;

        // Attempt to open the app
        window.location.href = appUrl;

        // Fallback to web if app doesn't open
        setTimeout(() => {
            window.location.href = WEB_URL;
        }, 4000);
    }

    setTimeout(() => {
        window.location.href = WEB_URL;
    }, 2000);

    // openEvents();
</script>

<Layout
    title="Maria Montserrat"
    description="Redirecting you to Maria's events page."
    noindex={true}
    showHeader={false}
    showFooter={false}
>
    <div class="flex h-screen">
        <div class="m-auto text-center">

            <div class="py-10 relative">
                <div>
                    <a
                        href={WEB_URL}
                        class="inline-block rounded-lg bg-primary-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-primary-700"
                    >
                        Click here if nothing happens
                    </a>
                </div>

                <Heading tag="h1" class="text-white mix-blend-difference absolute top-1/2 -mt-5 left-0 right-0 z-10">Loading..</Heading>
                <Spinner class="w-full h-full max-w-[400px] max-h-[400px]" type="pulse" color="rose" />
            </div>

        </div>
    </div>
</Layout>
